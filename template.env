POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_postgres_db

DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=postgres
DB_PORT=5432
DB_NAME=your_db_name

SIMILARITY_THRESHOLD=0.75
YOUTUBE_SIMILARITY_THRESHOLD=0.62
LINK_SIMILARITY_THRESHOLD=0.55
EMBEDDING_MODEL=all-mpnet-base-v2
STT_MODEL=small
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
LANGEXTRACT_ENABLED=true
LANGEXTRACT_MODEL_ID=llama3.2:3b
LANGEXTRACT_MODEL_URL=http://ollama:11434
CATEGORY_NAME_LLM_ENABLED=true
CATEGORY_NAME_LLM_MODEL_ID=llama3.2:3b
